{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the app",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The user's unique ID"
        },
        "email": {
          "type": "string",
          "format": "email",
          "description": "The user's email address"
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name"
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL"
        },
        "isPremium": {
          "type": "boolean",
          "description": "Whether the user has a premium subscription"
        },
        "notificationsEnabled": {
          "type": "boolean",
          "description": "Whether the user has enabled notifications"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the user was created"
        }
      },
      "required": ["uid", "createdAt"]
    },
    "Favorite": {
      "title": "Favorite",
      "description": "A quote favorited by a user",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who favorited the quote"
        },
        "quoteId": {
          "type": "string",
          "description": "The ID of the favorited quote"
        },
        "text": {
          "type": "string",
          "description": "The text of the quote"
        },
        "author": {
          "type": "string",
          "description": "The author of the quote"
        },
        "category": {
          "type": "string",
          "description": "The category of the quote"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the quote was favorited"
        }
      },
      "required": ["userId", "quoteId", "text", "author", "category", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "User profiles"
    },
    "favorites/{favoriteId}": {
      "schema": {
        "$ref": "#/entities/Favorite"
      },
      "description": "User favorites"
    }
  }
}
